<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <property name="banManagerSchema" value="ban_manager"/>

    <changeSet id="ban-manager-001-create-schema" author="Mofurka">
        <sql dbms="postgresql">
            CREATE SCHEMA IF NOT EXISTS ${banManagerSchema};
        </sql>
    </changeSet>

    <changeSet id="ban-manager-002-create-ban-records" author="Mofurka">
        <createTable
                tableName="ban_records"
                schemaName="${banManagerSchema}">

            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="varchar(255)">
                <constraints nullable="true"/>
            </column>

            <column name="player_uuid" type="varchar(32)">
                <constraints nullable="true"/>
            </column>

            <column name="ip_address" type="varchar(45)">
                <constraints nullable="true"/>
            </column>

            <column name="reason" type="varchar(255)">
                <constraints nullable="false"/>
            </column>

            <column name="banned_by" type="varchar(255)">
                <constraints nullable="false"/>
            </column>

            <column name="permanent" type="boolean">
                <constraints nullable="false"/>
            </column>

            <column name="banned_at" type="java.sql.Types.TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="expires_at" type="java.sql.Types.TIMESTAMP"/>
        </createTable>
    </changeSet>


</databaseChangeLog>
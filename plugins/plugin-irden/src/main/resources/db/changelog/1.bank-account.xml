<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1784547246749-1" author="mofuro">
        <createSequence incrementBy="50" sequenceName="revinfo_seq" startValue="1"/>
    </changeSet>
    <changeSet id="1784547246749-2" author="mofuro">
        <createTable tableName="revchanges">
            <column name="rev" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="entityname" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="1784547246749-3" author="mofuro">
        <createTable tableName="revinfo">
            <column name="rev" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_revinfo"/>
            </column>
            <column name="revtstmp" type="BIGINT"/>
        </createTable>
    </changeSet>
    <changeSet id="1784547246749-4" author="mofuro">
        <addForeignKeyConstraint baseColumnNames="rev" baseTableName="revchanges"
                                 constraintName="fk_revchanges_on_default_tracking_modified_entities_changelog"
                                 referencedColumnNames="rev" referencedTableName="revinfo"/>
    </changeSet>
    <changeSet id="1784547246905-1" author="mofuro">
        <createTable schemaName="irden" tableName="account_transaction">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_account_transaction"/>
            </column>
            <column name="operation_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="from_account_id" type="UUID"/>
            <column name="to_account_id" type="UUID"/>
            <column name="amount" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="from_balance_after" type="BIGINT"/>
            <column name="to_balance_after" type="BIGINT"/>
            <column name="description" type="VARCHAR(256)"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1784547246905-2" author="mofuro">
        <createTable schemaName="irden" tableName="game_account">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_game_account"/>
            </column>
            <column name="owner_type" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="owner_name" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="account_code" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="balance" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1784547246905-3" author="mofuro">
        <addUniqueConstraint columnNames="operation_id" constraintName="uk_account_transaction_operation_id"
                             schemaName="irden" tableName="account_transaction"/>
    </changeSet>
    <changeSet id="1784547246905-4" author="mofuro">
        <addUniqueConstraint columnNames="owner_type, owner_id, account_code"
                             constraintName="uk_game_account_owner_code" schemaName="irden" tableName="game_account"/>
    </changeSet>
    <changeSet id="1784547246905-5" author="mofuro">
        <createIndex indexName="idx_account_transaction_created_at" schemaName="irden" tableName="account_transaction">
            <column name="created_at"/>
        </createIndex>
    </changeSet>
    <changeSet id="1784547246905-8" author="mofuro">
        <createIndex indexName="idx_game_account_owner" schemaName="irden" tableName="game_account">
            <column name="owner_type"/>
            <column name="owner_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="1784547246905-9" author="mofuro">
        <createIndex indexName="idx_game_account_status" schemaName="irden" tableName="game_account">
            <column name="status"/>
        </createIndex>
    </changeSet>
    <changeSet id="1784547246905-10" author="mofuro">
        <addForeignKeyConstraint baseColumnNames="from_account_id" baseTableName="account_transaction"
                                 baseTableSchemaName="irden" constraintName="FK_ACCOUNT_TRANSACTION_FROM_ACCOUNT"
                                 referencedColumnNames="id" referencedTableName="game_account"
                                 referencedTableSchemaName="irden"/>

        <createIndex indexName="idx_account_transaction_from_account" schemaName="irden"
                     tableName="account_transaction">
            <column name="from_account_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="1784547246905-11" author="mofuro">
        <addForeignKeyConstraint baseColumnNames="to_account_id" baseTableName="account_transaction"
                                 baseTableSchemaName="irden" constraintName="FK_ACCOUNT_TRANSACTION_TO_ACCOUNT"
                                 referencedColumnNames="id" referencedTableName="game_account"
                                 referencedTableSchemaName="irden"/>

        <createIndex indexName="idx_account_transaction_to_account" schemaName="irden" tableName="account_transaction">
            <column name="to_account_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>